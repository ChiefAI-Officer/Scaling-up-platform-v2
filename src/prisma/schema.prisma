// ============================================
// JV-11 + JV-22: Workflow System
// ============================================

model Workflow {
  id              String   @id @default(cuid())
  name            String   // e.g., "Standard Pre-Event Sequence"
  description     String?
  isActive        Boolean  @default(true)
  isTemplate      Boolean  @default(false) // Admin-created templates coaches can clone
  categoryId      String?  // Feb25 Sprint 5: FK to Category for auto-assignment on approval
  workshopFormat  String?  // Feb25 Sprint 5: "IN_PERSON" or "VIRTUAL" — null = any format
  workflowPhase   String?  // Feb25 Sprint 5: "PRE_EVENT" or "POST_EVENT" — for auto-assign matching
  createdBy       String   // userId who created the workflow
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category    Category?    @relation(fields: [categoryId], references: [id])
  steps       WorkflowStep[]
  assignments WorkflowAssignment[]

  @@map("workflows")
}

model WorkflowStep {
  id         String @id @default(cuid())
  workflowId String
  sortOrder  Int    // Execution order within the workflow

  // What to do
  // Allowed values: EMAIL_ATTENDEES, EMAIL_COACH, EMAIL_STAFF, EMAIL_CUSTOM, NOTIFICATION
  stepType String

  // Email content (inline or from template)
  emailTemplateId String?   // Optional FK to reusable EmailTemplate
  subject         String?   // Override or inline subject
  body            String?   // Override or inline HTML body (supports {{ variables }})

  // For EMAIL_CUSTOM: JSON array of email addresses
  customRecipients String?

  // JV-22: Date-relative scheduling
  // triggerType values: RELATIVE_TO_EVENT, ON_REGISTRATION, ON_APPROVAL
  triggerType   String
  offsetDays    Int?       // Days relative to event (negative = before, positive = after)
  offsetHours   Int?       // Hours offset for fine-grained timing
  sendTimeOfDay String?    // "09:00" — preferred send time (defaults to event time if null)

  // JV-12: File attachments placeholder (future Track B)
  attachments String? // JSON array of { filename, storageKey, contentType }

  // BUG-06: Pinned survey template for SEND_SURVEY_LINK steps
  surveyTemplateId String? // Optional FK to SurveyTemplate; overrides category-based auto-matching

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow        Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  emailTemplate   EmailTemplate?   @relation(fields: [emailTemplateId], references: [id])
  surveyTemplate  SurveyTemplate?  @relation(fields: [surveyTemplateId], references: [id], onDelete: SetNull)
  executions      WorkflowStepExecution[]
  fileAttachments FileAttachment[] // JV-12: Files attached to this step

  @@index([workflowId])
  @@map("workflow_steps")
}

model WorkflowAssignment {
  id           String   @id @default(cuid())
  workflowId   String
  workshopId   String
  workshopCode String   // Denormalized for easy lookup (JV-04)
  isActive     Boolean  @default(true)
  assignedBy   String   // userId who assigned the workflow
  assignedAt   DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workflowId, workshopId])
  @@index([workshopId])
  @@index([workshopCode])
  @@map("workflow_assignments")
}

model WorkflowStepExecution {
  id             String    @id @default(cuid())
  stepId         String
  workshopId     String    // Which workshop this execution is for
  // Both cascades (step + workshop) are intentional and independent:
  // - step cascade: handles workflow template edits/deletions
  // - workshop cascade: handles workshop permanent deletion
  workshop       Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  registrationId String?   // Which registrant (for attendee-targeted emails)

  // ENH-MAY6-10: parent/child rollup model. Top-level rows have parentId=null
  // (existing rows + parent rollups). Per-recipient child rows have parentId
  // set + non-null registrationId + non-null recipientEmail. Composite unique
  // (parentId, registrationId) makes child upserts idempotent across replays.
  // Coach surfaces filter parentId=null to avoid leaking recipient PII.
  parentId       String?
  parent         WorkflowStepExecution?  @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children       WorkflowStepExecution[] @relation("ParentChildren")

  // ENH-MAY6-10: snapshot of the recipient email at row-write time. Set on
  // child rows; null on parent/legacy rows.
  recipientEmail String?

  // Execution state: PENDING, SCHEDULED, SENT, FAILED, SKIPPED
  status       String    @default("PENDING")
  scheduledFor DateTime? // When Inngest should fire
  executedAt   DateTime?
  errorMessage String?
  attempts     Int       @default(0)

  // Inngest tracking
  inngestEventId String? // For cancellation/retry tracking

  createdAt DateTime @default(now())

  step WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([parentId, registrationId], name: "WorkflowStepExecution_parent_recipient_unique")
  @@index([stepId])
  @@index([workshopId])
  @@index([status])
  @@index([scheduledFor])
  @@index([parentId])
  @@map("workflow_step_executions")
}

