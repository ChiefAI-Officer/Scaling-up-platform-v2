generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Authentication & Users
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("STAFF")
  image         String?
  passwordHash  String?   // Sprint 1: Password hashing for credentials auth
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  coachProfile Coach?     // Sprint 1: User↔Coach FK

  // Assessment v7.6 back-relations (compile-time only; no new DB columns on users table)
  assessmentTemplatesCreated AssessmentTemplate[]          @relation("AssessmentTemplateCreatedBy")
  assessmentCampaignsCreated AssessmentCampaign[]          @relation("AssessmentCampaignCreatedBy")
  accessGroupsCreated        AccessGroup[]                 @relation("AccessGroupCreatedBy")
  accessGroupCoachLinks      AccessGroupCoach[]            @relation("AccessGroupCoachAddedBy")
  accessGroupTemplateLinks   AccessGroupTemplate[]         @relation("AccessGroupTemplateAddedBy")
  organizationOwnershipEvents OrganizationOwnershipEvent[] @relation("OrgOwnershipPerformedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================
// Coaches
// ============================================

model Coach {
  id                  String    @id @default(cuid())
  userId              String?   @unique  // Sprint 1: Link to User for auth
  hubspotId           String?   @unique
  circleId            String?   @unique
  email               String    @unique
  firstName           String
  lastName            String
  phone               String?
  company             String?
  title               String?   // Professional title/credentials, e.g., "Scaling Up Certified Coach"
  bio                 String?
  profileImage        String?
  linkedinUrl         String?
  showBookCallCta     Boolean   @default(true)
  bookCallUrl         String?
  certificationStatus String    @default("PENDING")
  certificationExpiry DateTime?
  paymentStatus       String    @default("PENDING")
  territory           String?
  performanceMetrics  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  syncedAt            DateTime?

  user            User?            @relation(fields: [userId], references: [id])  // Sprint 1: User relation
  workshops       Workshop[]
  certifications  CoachCertification[]
  approvals       ApprovalQueue[]
  followUpReports FollowUpReport[]

  // Assessment v7.6 back-relations (compile-time only; no new DB columns on coaches table)
  ownedOrganizations          Organization[]
  accessGroupMemberships      AccessGroupCoach[]
  createdAssessmentCampaigns  AssessmentCampaign[]            @relation("AssessmentCampaignCreatedByCoach")
  orgOwnershipEventsFromCoach OrganizationOwnershipEvent[]    @relation("OrgOwnershipFromCoach")
  orgOwnershipEventsToCoach   OrganizationOwnershipEvent[]    @relation("OrgOwnershipToCoach")
  campaignWizardDraft         CampaignWizardDraft?

  @@map("coaches")
}

model CoachCertification {
  id             String    @id @default(cuid())
  coachId        String
  workshopTypeId String
  certifiedAt    DateTime  @default(now())
  expiresAt      DateTime?
  status         String    @default("ACTIVE")

  coach        Coach        @relation(fields: [coachId], references: [id], onDelete: Cascade)
  workshopType WorkshopType @relation(fields: [workshopTypeId], references: [id])

  @@unique([coachId, workshopTypeId])
  @@map("coach_certifications")
}

// ============================================
// Workshop Types (Templates)
// ============================================

model WorkshopType {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  description             String?
  shortDescription        String?
  durationOptions         String // JSON string
  materials               String? // JSON string
  marketingTemplates      String? // JSON string
  pricingTiers            String? // JSON string
  preWorkshopInstructions String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  workshops      Workshop[]
  certifications CoachCertification[]

  @@map("workshop_types")
}

// ============================================
// Workshops (Events)
// ============================================

model Workshop {
  id             String    @id @default(cuid())
  workshopCode   String    @unique // JV-03: Human-readable unique ID (e.g., WS-2026-A1B2)
  coachId        String
  workshopTypeId String?   // JV-16: Made optional during migration (workshopType being deprecated)
  categoryId     String?   // JV-16: FK to dynamic Category model (replaces enum)
  category       WorkshopCategory @default(AI) // JV-16: Kept during migration, will be removed

  // Event Details
  title        String
  description  String?
  format       String // IN_PERSON, VIRTUAL, HYBRID
  duration     String // 'full-day', 'half-day', 'virtual-2hr'
  eventDate    DateTime
  eventEndDate DateTime?
  eventTime    String?
  timezone     String    @default("America/New_York")

  // Location (for in-person)
  venueName         String?
  venueAddress      String? // JSON string
  venueInstructions String? @map("parkingInstructions") // Feb25: Renamed from parkingInstructions

  // Virtual (for online)
  virtualPlatform String? // 'zoom', 'teams', 'meet' — no longer in form but kept for historical data
  virtualLink     String?

  // Pricing
  isFree              Boolean   @default(false)
  priceCents          Int?
  earlyBirdPriceCents Int?      // Deprecated: kept for historical data
  earlyBirdDeadline   DateTime? // Deprecated: kept for historical data
  pricingTierId       String?   // JV-17: FK to PricingTier model

  // Feb25: Targeting
  geoTargetAreas  String? // Feb25: Comma-separated geographic target areas
  excludedClients String? // Feb25: Comma-separated excluded client names

  // MR-21: Multi-coupon codes (JSON array of {code, discountPercent, singleUse})
  coupons String @default("[]")

  // Status & Pipeline — JV-02: Jeff's 6 stages
  // INFO_REQUESTED, AWAITING_APPROVAL, PRE_EVENT, POST_EVENT, COMPLETED, DENIED, CANCELED
  status String @default("INFO_REQUESTED")

  // Generated Assets
  landingPageSlug String? @unique

  // External IDs
  hubspotCampaignId String?
  stripeProductId   String?
  stripePriceId     String?

  // Capacity
  maxAttendees Int @default(50)

  // Workshop Locking (48h before event)
  isLocked  Boolean   @default(false)
  lockedAt  DateTime?
  lockedBy  String?   // User ID who locked it, or 'SYSTEM'

  // JV-27: Terms acceptance
  termsAcceptedAt DateTime?

  // BUG-MAY4-2: atomic guard — set when the "Workshop Ready" email is sent (null = not yet sent)
  workshopBuiltEmailSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach           Coach               @relation(fields: [coachId], references: [id], onDelete: Cascade)
  workshopType    WorkshopType?       @relation(fields: [workshopTypeId], references: [id])
  workshopCategory Category?          @relation(fields: [categoryId], references: [id])
  pricingTier     PricingTier?        @relation(fields: [pricingTierId], references: [id])
  registrations   Registration[]
  campaigns       MarketingCampaign[]
  tasks           AutomationTask[]
  surveys         Survey[]
  approvals       ApprovalQueue[]
  landingPages    LandingPage[]
  followUpReports FollowUpReport[]
  workshopPages       WorkshopPage[]        // JV-10: Unique pages per workshop
  workflowAssignments WorkflowAssignment[]  // JV-11: Workflow linkage
  fileAttachments        FileAttachment[]      // JV-12: File attachments
  workflowStepExecutions WorkflowStepExecution[]
  adminNote              WorkshopAdminNote?    // ENH-MAY6-2: admin-only side table

  @@index([coachId])
  @@index([status])
  @@index([eventDate])
  @@index([categoryId])
  @@map("workshops")
}

// ============================================
// Admin-Only Side Tables (ENH-MAY6-2)
// ============================================
// Side table over column for structural privacy. Coach-facing Prisma includes
// on Workshop never reach this table — there is no path that can leak admin
// notes to a coach payload via accidental select:* or include:{workshop:true}.

model WorkshopAdminNote {
  id         String   @id @default(cuid())
  workshopId String   @unique
  body       String
  updatedBy  String   // User.id of the admin/staff who last saved
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@map("workshop_admin_notes")
}

// ============================================
// Registrations
// ============================================

model Registration {
  id         String @id @default(cuid())
  workshopId String

  // Attendee Info
  email     String
  firstName String
  lastName  String
  company   String?
  jobTitle  String?
  phone     String?

  // Payment
  paymentStatus   String  @default("PENDING")
  stripePaymentId String?
  stripeSessionId String?
  amountPaidCents Int?

  // External Sync
  hubspotContactId String?

  // Status
  status      String    @default("REGISTERED")
  checkedInAt DateTime?

  // Feb25: Attendance tracking (Sprint 3 UI, pre-added here)
  attended    Boolean   @default(false)
  attendedAt  DateTime?

  // Feb25: Marketing opt-in (Sprint 6 UI, pre-added here)
  marketingOptIn Boolean @default(false)

  // Stripe webhook fix (May 2026): function-level idempotency marker for
  // processPaymentCompleted Inngest function. NULL = side effects pending.
  paymentProcessedAt DateTime?
  // Stripe webhook fix (May 2026): atomic claim for at-most-once paid
  // confirmation email. Pre-empted before SMTP send; rolled back on error.
  notificationSentAt DateTime?

  // Q-MAY6-1: refund-needed digest. Suzanne (STAFF) marks rows refunded after
  // processing the refund in the Stripe dashboard. stripeRefundId is the
  // operator-provided evidence ("re_..."), required at mark-refunded time.
  refundedAt     DateTime?
  refundedBy     String?
  stripeRefundId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  surveys  Survey[]

  @@index([workshopId])
  @@index([email])
  // CHG-03: paid thank-you pages look up the registration by stripeSessionId
  // to scope it to the workshop. Without this index, every paid thank-you
  // hit does a sequential scan against the registrations table.
  @@index([stripeSessionId])
  @@index([paymentProcessedAt])
  @@index([notificationSentAt])
  @@map("registrations")
}

// ============================================
// Marketing Campaigns
// ============================================

model MarketingCampaign {
  id           String @id @default(cuid())
  workshopId   String
  campaignType String // COACH_PROMO, SCALING_UP_EMAIL, etc.

  // Content
  content String? // JSON string
  assets  String? // JSON string

  // Scheduling
  scheduledSends String? // JSON string

  // Tracking
  hubspotCampaignId String?
  metrics           String? // JSON string

  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@map("marketing_campaigns")
}

// ============================================
// Automation Tasks
// ============================================

model AutomationTask {
  id         String @id @default(cuid())
  workshopId String
  taskType   String // 'validate_coach', 'generate_landing_page', etc.
  status     String @default("PENDING")

  inputData    String? // JSON string
  outputData   String? // JSON string
  errorMessage String?

  attempts    Int @default(0)
  maxAttempts Int @default(3)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@map("automation_tasks")
}

// ============================================
// Surveys & Feedback (JV-13: Custom Form Builder)
// ============================================

// Survey templates — reusable question sets (e.g., "Standard Post-Event Feedback")
model SurveyTemplate {
  id          String   @id @default(cuid())
  name        String   // e.g., "Post-Workshop Satisfaction"
  description String?
  surveyType  String   // PRE_WORKSHOP, POST_WORKSHOP, NPS
  categoryId  String?  // Optional: link to Category for auto-assignment by workshop category
  isActive    Boolean  @default(true)
  createdBy   String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category      Category?        @relation(fields: [categoryId], references: [id])
  questions     SurveyQuestion[]
  surveys       Survey[]
  workflowSteps WorkflowStep[]   // BUG-06: Steps that pin this survey template

  @@index([categoryId])
  @@index([surveyType])
  @@map("survey_templates")
}

// Individual questions in a template
model SurveyQuestion {
  id         String @id @default(cuid())
  templateId String
  sortOrder  Int    // Display order

  // Question definition
  // questionType: TEXT, TEXTAREA, RATING, NPS, SINGLE_CHOICE, MULTI_CHOICE, YES_NO
  questionType String
  label        String   // The question text
  description  String?  // Optional help text
  isRequired   Boolean  @default(true)

  // For SINGLE_CHOICE / MULTI_CHOICE: JSON array of option strings
  options String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template SurveyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  SurveyAnswer[]

  @@index([templateId])
  @@map("survey_questions")
}

// A survey instance assigned to a specific workshop
model Survey {
  id             String  @id @default(cuid())
  templateId     String? // FK to SurveyTemplate (null for legacy Typeform surveys)
  registrationId String?
  workshopId     String
  workshopCode   String? // Denormalized (JV-04)
  surveyType     String  // PRE_WORKSHOP, POST_WORKSHOP, NPS

  // Legacy Typeform responses (kept for backward compat)
  responses String? // JSON string
  npsScore  Int?

  sentAt      DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  template     SurveyTemplate? @relation(fields: [templateId], references: [id])
  registration Registration?   @relation(fields: [registrationId], references: [id])
  workshop     Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  answers      SurveyAnswer[]

  @@index([workshopId])
  @@index([workshopCode])
  @@map("surveys")
}

// Individual answers per question per survey response
model SurveyAnswer {
  id         String @id @default(cuid())
  surveyId   String
  questionId String

  // The answer (stored as string; JSON for multi-choice)
  value    String?
  numValue Int?    // Numeric extraction for RATING/NPS aggregation

  createdAt DateTime @default(now())

  survey   Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([surveyId, questionId]) // One answer per question per survey
  @@index([questionId])
  @@map("survey_answers")
}

// ============================================
// JV-12: File Attachments (Vercel Blob)
// ============================================

model FileAttachment {
  id           String   @id @default(cuid())
  filename     String   // Original filename
  blobUrl      String   // Vercel Blob URL
  contentType  String   // MIME type
  sizeBytes    Int      // File size in bytes
  workshopId   String?  // Optional: linked to a workshop
  workshopCode String?  // Denormalized for fast lookup
  workflowStepId String? // Optional: linked to a workflow step for email attachment
  uploadedBy   String   // userId who uploaded
  category     String?  // e.g., "presentation", "handout", "resource"
  createdAt    DateTime @default(now())

  workshop     Workshop?     @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  workflowStep WorkflowStep? @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)

  @@index([workshopId])
  @@index([workshopCode])
  @@index([workflowStepId])
  @@map("file_attachments")
}

// ============================================
// V2: Approval Queue (Human-in-the-Loop)
// ============================================

model ApprovalQueue {
  id          String         @id @default(cuid())
  type        ApprovalType
  workshopId  String?
  coachId     String
  requestData String // JSON string
  status      ApprovalStatus @default(PENDING)
  requestedAt DateTime       @default(now())
  requestedBy String?        // Name/email of person who requested
  respondedAt DateTime?
  respondedBy String?        // User who responded (email or "SYSTEM")
  decision    String?
  notes       String?
  responseReason String?     // Reason for approval/denial
  escalatedAt DateTime?      // When escalated to higher authority
  coachResponse  String?     // MR-33: Coach's response to INFO_REQUESTED questions
  counterOfferCents Int?
  counterOfferNote  String?

  workshop Workshop?         @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  coach    Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  messages ApprovalMessage[]

  @@index([status])
  @@index([coachId])
  @@map("approval_queue")
}

model ApprovalMessage {
  id         String        @id @default(cuid())
  approvalId String
  approval   ApprovalQueue @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  from       String        // "ADMIN" | "COACH"
  text       String
  // BUG-06–08 (May 4 2026): true for rows created by the one-time backfill
  // script (scripts/backfill-approval-messages.ts). Live writers leave the
  // default false. Used both as a clean rollback key
  // (`DELETE WHERE synthetic = true`) and to disambiguate dup checks.
  synthetic  Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([approvalId])
  @@index([approvalId, synthetic])
  @@map("approval_messages")
}

// ============================================
// V2: Audit Logging
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String // 'Workshop', 'Registration', 'Coach', etc.
  entityId    String
  action      String // 'CREATE', 'UPDATE', 'DELETE', 'APPROVE', 'DENY'
  performedBy String? // User email or 'SYSTEM'
  changes     String // JSON string of changed fields
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ============================================
// V2: Email Templates
// ============================================

model EmailTemplate {
  id         String    @id @default(cuid())
  name       String    @unique
  subject    String
  body       String // HTML template with {{ variables }}
  variables  String // JSON array of variable names
  type       EmailType
  timingDays Int? // Days before/after event (negative = before)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workflowSteps WorkflowStep[] // JV-11: Steps that reference this template

  @@map("email_templates")
}

// ============================================
// V2: Landing Pages
// ============================================

model LandingPage {
  id               String              @id @default(cuid())
  workshopId       String
  template         LandingPageTemplate
  slug             String              @unique
  content          String              // JSON with all dynamic variables
  status           PageStatus          @default(DRAFT)
  isActiveTemplate Boolean             @default(false) // Feb25 Sprint 5: marks this page as the active template for auto-build
  categoryId       String?             // FIG-005: FK to Category — null = global template (applies to all)
  sourceTemplateId String?             // Tracks which PageTemplate this page was cloned from (informational, no FK)
  // CHG-03 (May 4 2026): customCode rendered on THANK_YOU pages for iDev
  // affiliate tracking. Copied at build time from the source PageTemplate;
  // never accepted from request bodies on coach-accessible routes.
  customCode       String?
  // TEMPLATE-02 (Jun 3 2026): sanitized raw HTML override copied from
  // PageTemplate.customHtml at build-time (variables HTML-escaped + interpolated).
  // SOLO_LANDING + DUO_LANDING only; null on every other template type.
  customHtml       String?
  publishedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  workshop Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([workshopId, template])
  @@index([categoryId])
  @@map("landing_pages")
}

// ============================================
// V2: Page Templates (independent of workshops)
// ============================================

model PageTemplate {
  id           String              @id @default(cuid())
  name         String              // e.g., "AI Workshop Solo Landing"
  templateType LandingPageTemplate // BIO_PAGE, SOLO_LANDING, DUO_LANDING, REGISTRATION, THANK_YOU
  categoryId   String?             // null = global template (applies to all categories)
  content      String              // JSON string with {{variable}} placeholders (TEXT column)
  customCode   String?             // ENH-06: affiliate / tracking code (stored only, not rendered)
  customHtml   String?             // TEMPLATE-02 (Jun 3 2026): sanitized raw HTML override. When non-empty, replaces React template at render. SOLO_LANDING + DUO_LANDING only.
  isActive     Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([templateType, categoryId])
  @@map("page_templates")
}

// ============================================
// V2: Workshop Drafts (Auto-Save for Wizard)
// ============================================

model WorkshopDraft {
  id          String   @id @default(cuid())
  userId      String   // User who started the draft
  workshopId  String?  @unique // Null if not yet saved, linked to Workshop if resumed
  currentStep Int      @default(1) // 1=Details, 2=Schedule, 3=Pricing
  stepsData   String   // JSON containing all form data across steps
  lastSavedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("workshop_drafts")
}

// ============================================
// Assessment v7.6 — Campaign Wizard auto-save
// (mirrors WorkshopDraft precedent; one row per coach)
// ============================================

model CampaignWizardDraft {
  id           String   @id @default(cuid())
  coachId      String   @unique
  currentStep  Int      @default(1)
  stepsData    String   // JSON-stringified wizard state
  lastSavedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coach        Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@map("assessment_campaign_wizard_drafts")
}

// ============================================
// V2: 90-Day Follow-Up Reports
// ============================================

model FollowUpReport {
  id            String       @id @default(cuid())
  workshopId    String
  coachId       String
  dueDate       DateTime // Event date + 90 days
  submittedAt   DateTime?
  reportData    String? // JSON with participant outcomes
  status        ReportStatus @default(PENDING)
  remindersSent Int          @default(0)
  createdAt     DateTime     @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  coach    Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([status])
  @@map("follow_up_reports")
}

// ============================================
// JV-16: Dynamic Workshop Categories (replaces WorkshopCategory enum)
// ============================================

model Category {
  id                 String   @id @default(cuid())
  name               String   @unique // e.g., "AI Workshop", "Exit Workshop"
  slug               String   @unique // e.g., "ai", "exit-and-valuation"
  description        String?
  defaultTitle       String?  // Feb25: Auto-title template (e.g., "Scaling Up AI Workshop")
  defaultDescription String?  // Feb25: Auto-description populated on category select
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workshops       Workshop[]
  pricingTiers    PricingTier[]
  surveyTemplates SurveyTemplate[]
  workflows       Workflow[]
  landingPages    LandingPage[]    // FIG-005: Templates scoped to this category
  pageTemplates   PageTemplate[]

  @@map("categories")
}

// ============================================
// JV-17: Pricing Tiers (replaces freeform price input)
// ============================================

model PricingTier {
  id          String   @id @default(cuid())
  categoryId  String
  name        String   // e.g., "Standard", "Early Bird", "Group Rate"
  amountCents Int      // Price in cents
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  workshops Workshop[]

  @@index([categoryId])
  @@map("pricing_tiers")
}

// ============================================
// JV-10: Workshop Pages (unique pages per workshop)
// ============================================

model WorkshopPage {
  id           String   @id @default(cuid())
  workshopId   String
  workshopCode String   // Denormalized for easy lookup
  pageType     String   // LANDING, PAYMENT, THANK_YOU
  templateId   String?  // Reference to template used
  content      String?  // JSON with page content
  slug         String?  @unique // Public URL slug
  published    Boolean  @default(false)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, pageType])
  @@index([workshopCode])
  @@map("workshop_pages")
}

