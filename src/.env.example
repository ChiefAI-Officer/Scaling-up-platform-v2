# ===========================================
# Scaling Up Platform v2 - Environment Config
# ===========================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/scaling_up_v2?schema=public"

# Authentication (NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-32-character-secret-here"

# HubSpot CRM
HUBSPOT_ACCESS_TOKEN="your-hubspot-access-token"
# Request sandbox from Carolyn for testing

# Stripe Payments
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key"
# iDevAffiliate tracking script URL (sale tracking endpoint)
IDEV_SCRIPT_URL="https://your-idev-domain.com/sale.php"

# Circle.so (SunHub) - CRITICAL: Validate Day 1
CIRCLE_API_KEY="your-circle-api-key"
CIRCLE_COMMUNITY_ID="your-community-id"
# API Docs: https://api.circle.so/docs

# Inngest (background jobs - required for production)
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# Redis Cache (optional for dev, required for prod)
REDIS_URL="redis://localhost:6379"

# Email/SMTP (for HITL notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@scalingup.com"

# Microsoft Teams (optional - alternative to email for HITL)
# TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..."

# Application URLs
APP_URL="http://localhost:3000"
LANDING_PAGE_BASE_URL="http://localhost:3000/workshops"

# Typeform Survey IDs (existing forms)
TYPEFORM_READINESS_SURVEY_ID="your-readiness-survey-id"
TYPEFORM_POST_WORKSHOP_SURVEY_ID="your-post-workshop-survey-id"
TYPEFORM_COACH_FEEDBACK_SURVEY_ID="your-coach-feedback-survey-id"

# Feature Flags
ENABLE_HITL_APPROVALS="true"
ENABLE_EMAIL_AUTOMATION="true"

# Security - REQUIRED for production
APPROVAL_LINK_SECRET="your-32-character-approval-secret-here"
FILE_ACCESS_SECRET="your-32-character-file-access-secret-here"
# Optional: minimum workshop stage required before workflow attachments are deliverable.
# Valid values: REQUESTED, AWAITING_APPROVAL, PRE_EVENT, POST_EVENT, COMPLETED, CANCELED
WORKFLOW_ATTACHMENT_MIN_STATUS="PRE_EVENT"

# Demo Mode - set to "true" ONLY for development/testing
# In production, this should NOT be set or set to "false"
# Guardrail (P0-SEC-03): if DEMO_MODE is true outside local development,
# demo authentication is automatically disabled and a security alert is logged.
# DEMO_MODE="true"

# LLM API Keys (Multi-Gateway Router)
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="sk-your-openai-key"

# Admin Configuration
ADMIN_EMAIL="suzanne@scalingup.com"
ESCALATION_EMAIL="jeff@scalingup.com"
