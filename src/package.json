{
  "name": "scaling-up-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/check-migration-safety.mjs && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "test:load": "node scripts/load-test.js",
    "test:security": "node scripts/security-audit.js",
    "test:phase7": "npm run test && npm run test:e2e -- --project=chromium && npm run test:security",
    "eval:hitl-baseline": "tsx scripts/hitl-baseline-report.ts",
    "audit": "npm audit --audit-level=high",
    "validate:redis:local": "npx tsx scripts/validate-local-redis.ts",
    "validate:inngest:local": "npx tsx scripts/validate-local-inngest.ts",
    "validate:p0-rel-proof": "npx tsx scripts/run-p0-rel-proof.ts",
    "validate:status-workshopcode": "npx tsx scripts/validate-status-workshopcode.ts",
    "validate:local:queues": "npm run validate:redis:local && npm run validate:inngest:local",
    "deploy:staging": "vercel",
    "deploy:prod": "vercel --prod",
    "db:generate": "prisma generate",
    "db:push": "node scripts/safe-prisma.mjs db push",
    "db:migrate": "node scripts/safe-prisma.mjs migrate dev",
    "db:check-migrations": "node scripts/check-migration-safety.mjs",
    "snapshot:prod": "npx tsx scripts/snapshot-prod-tables.ts",
    "restore:from-snapshot": "npx tsx scripts/restore-from-snapshot.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "seed:rockefeller": "npx tsx prisma/seed-rockefeller-assessment.ts",
    "seed:qsp-v1": "npx tsx prisma/seed-qsp-v1-assessment.ts",
    "seed:qsp-v2": "npx tsx prisma/seed-qsp-v2-assessment.ts",
    "seed:scaling-up-full": "npx tsx prisma/seed-scaling-up-full-assessment.ts",
    "db:studio": "prisma studio",
    "db:reset": "node scripts/safe-prisma.mjs migrate reset",
    "postinstall": "prisma generate",
    "validate:apis": "npx tsx scripts/validate-apis.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hubspot/api-client": "^13.4.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/parse5": "^6.0.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.2.0",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.34.1",
    "inngest": "^3.54.0",
    "ioredis": "^5.9.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "parse5": "^7.3.0",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-phone-number-input": "^3.4.16",
    "stripe": "^20.1.2",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.58.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "glob": "^11.1.0",
    "test-exclude": "^8.0.0"
  }
}
